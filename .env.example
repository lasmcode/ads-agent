# =============================================================================
# ADS Agent — environment template
# Copy to .env and fill in your values:  cp .env.example .env
# Do NOT commit .env (it is gitignored).
# =============================================================================

# --- PostgreSQL (docker-compose postgres service) ---
# ADS_DATABASE_URL must use the same user/password/db as below.
POSTGRES_DB=adsagent
POSTGRES_USER=adsagent
POSTGRES_PASSWORD=adsagent
POSTGRES_PORT=5432

# --- LLM: Google Gemini (via LiteLLM) ---
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Web search: Tavily ---
# Get your key at https://tavily.com
TAVILY_API_KEY=

# --- Observability: Langfuse Cloud (recommended) ---
# Create keys at https://cloud.langfuse.com → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Self-hosted alternative (generate keys in your local Langfuse instance):
# LANGFUSE_HOST=http://localhost:3000

# --- ADS Agent settings ---
ADS_RESEARCH_MODEL=gemini/gemini-2.5-flash
ADS_LLM_SUPERVISOR_MODEL=gemini/gemini-2.5-pro
ADS_LLM_WORKER_MODEL=gemini/gemini-2.5-flash
ADS_MAX_ITERATIONS=5
ADS_LOG_LEVEL=INFO
ADS_HTTP_TIMEOUT=15
ADS_MCP_TRANSPORT=stdio

# --- RAG / pgvector (Phase 3) ---
# Must match POSTGRES_* above when using local docker-compose.
ADS_DATABASE_URL=postgresql://adsagent:adsagent@localhost:5432/adsagent

# --- Evaluation Engine (Phase 6) ---
# Disabled by default to preserve Gemini free-tier quota. Set true when billing is ready.
ADS_EVAL_ENABLED=false
ADS_EVAL_SAMPLE_RATE=1.0
# Production: sample 5-15% of requests to control RAGAS cost
# ADS_EVAL_SAMPLE_RATE=0.10
ADS_EVAL_TIMEOUT_SECONDS=60
ADS_EVAL_MODEL=gemini/gemini-2.5-flash
EVAL_QUALITY_THRESHOLD=0.75
EVAL_FAITHFULNESS_THRESHOLD=0.85
EVAL_ANSWER_RELEVANCY_THRESHOLD=0.80
EVAL_CONTEXT_PRECISION_THRESHOLD=0.75

# --- FastAPI Gateway (Phase 7) ---
APP_ENV=development
ADS_API_HOST=0.0.0.0
ADS_API_PORT=8080
ADS_API_PIPELINE_TIMEOUT=120
# Comma-separated list — never use * in production
ADS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
