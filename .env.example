# =============================================================================
# ADS Agent — environment template
# Copy to .env and fill in your values:  cp .env.example .env
# Do NOT commit .env (it is gitignored).
# =============================================================================

# --- PostgreSQL (docker-compose postgres service) ---
# ADS_DATABASE_URL must use the same user/password/db as below.
POSTGRES_DB=adsagent
POSTGRES_USER=adsagent
POSTGRES_PASSWORD=adsagent
POSTGRES_PORT=5432

# --- LLM: Google Gemini (via LiteLLM) ---
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Web search: Tavily ---
# Get your key at https://tavily.com
TAVILY_API_KEY=

# --- Observability: Langfuse Cloud (recommended) ---
# Create keys at https://cloud.langfuse.com → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Self-hosted alternative (generate keys in your local Langfuse instance):
# LANGFUSE_HOST=http://localhost:3000

# --- ADS Agent settings ---
ADS_RESEARCH_MODEL=gemini/gemini-2.5-flash
ADS_LLM_SUPERVISOR_MODEL=gemini/gemini-2.5-pro
ADS_LLM_WORKER_MODEL=gemini/gemini-2.5-flash
ADS_MAX_ITERATIONS=5
ADS_LOG_LEVEL=INFO
ADS_HTTP_TIMEOUT=15
ADS_MCP_TRANSPORT=stdio

# --- RAG / pgvector (Phase 3) ---
# Must match POSTGRES_* above when using local docker-compose.
ADS_DATABASE_URL=postgresql://adsagent:adsagent@localhost:5432/adsagent
